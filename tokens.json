    "glow": { "value": "0 0 80px rgba(90,40,221,0.35)",                             "type": "shadow" }
  },
  "motion": {
    "easeOut":      { "value": "cubic-bezier(0.16, 1, 0.3, 1)", "type": "cubicBezier" },
