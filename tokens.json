{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Layout Studio Design System",
    "version": "2.0.0",
    "updated": "2026-04-20",
    "description": "One studio. Full-stack visual. Ecosystem native."
  },
  "color": {
    "black":       { "value": "#000000", "type": "color" },
    "charcoal":    { "value": "#1E1E1E", "type": "color" },
    "purple":      { "value": "#5A28DD", "type": "color", "description": "Primary brand accent — digital default" },
    "deepPurple":  { "value": "#3B1FA8", "type": "color" },
    "lavender":    { "value": "#9B7FE8", "type": "color" },
    "mauve":       { "value": "#AD72BD", "type": "color", "description": "Gradient mid-tone" },
    "white":       { "value": "#FFFFFF", "type": "color" },
    "offWhite":    { "value": "#F5F5F0", "type": "color" },
    "coral":       { "value": "#E8453C", "type": "color", "description": "Campaign only — not default. Reserved for special events and collaborations." },
    "cream":       { "value": "#FFF3CA", "type": "color", "description": "Gradient start — warm hero moments" },
    "peach":       { "value": "#FF9F94", "type": "color", "description": "Gradient second stop" },
    "surface": {
      "dark":       { "value": "#111111", "type": "color" },
      "darkMid":    { "value": "#1A1A1A", "type": "color" },
      "darkAlt":    { "value": "#2A2A2A", "type": "color" },
      "light":      { "value": "#F0F0F0", "type": "color" },
      "cream":      { "value": "#FDFDF5", "type": "color" }
    },
    "border": {
      "dark":    { "value": "rgba(255,255,255,0.08)",  "type": "color" },
      "darkMid": { "value": "rgba(255,255,255,0.14)",  "type": "color" },
      "light":   { "value": "#E0E0E0",                 "type": "color" },
      "purple":  { "value": "rgba(90,40,221,0.35)",    "type": "color" }
    }
  },
  "gradient": {
    "signature": {
      "value": "linear-gradient(135deg, #FFF3CA 0%, #FF9F94 33%, #AD72BD 66%, #7152DA 100%)",
      "type": "gradient",
      "description": "Default gradient for logos, hero moments, brand surfaces. Stops: Cream → Peach → Mauve → Purple."
    },
    "purple": {
      "value": "linear-gradient(180deg, #5A28DD 0%, #3B1FA8 100%)",
      "type": "gradient"
    },
    "dark": {
      "value": "linear-gradient(135deg, #1a0a3d 0%, #0d0d0d 60%)",
      "type": "gradient",
      "description": "Dark slide background with subtle purple warmth"
    }
  },
  "font": {
    "family": {
      "display": {
        "value": "Coolvetica, 'Arial Black', 'Helvetica Neue', sans-serif",
        "type": "fontFamily",
        "description": "Primary typeface. Use Heavy Crammed or Heavy Condensed for hero type. Never stretch."
      },
      "body": {
        "value": "'Founders Grotesk', Inter, -apple-system, sans-serif",
        "type": "fontFamily",
        "description": "Secondary typeface. Subheads, body, UI labels. Available in Light/Regular/Medium/Semibold/Bold."
      },
      "script": {
        "value": "Sailhill, cursive",
        "type": "fontFamily",
        "description": "Accent only. Used for 'The Occasional Deviation' moments — personality, not default."
      },
      "mono": {
        "value": "'JetBrains Mono', ui-monospace, Menlo, monospace",
        "type": "fontFamily",
        "description": "Code and technical labels."
      }
    },
    "size": {
      "hero":    { "value": "clamp(56px, 8vw, 120px)", "type": "dimension", "description": "Cover / statement. 10× body." },
      "display": { "value": "clamp(40px, 5vw, 72px)",  "type": "dimension", "description": "Section headlines. 4-5× body." },
      "h1":      { "value": "clamp(32px, 3.5vw, 48px)", "type": "dimension" },
      "h2":      { "value": "clamp(24px, 2.5vw, 36px)", "type": "dimension" },
      "h3":      { "value": "24px", "type": "dimension" },
      "h4":      { "value": "18px", "type": "dimension" },
      "body":    { "value": "15px", "type": "dimension" },
      "small":   { "value": "13px", "type": "dimension" },
      "caption": { "value": "11px", "type": "dimension" },
      "chrome":  { "value": "10px", "type": "dimension" }
    },
    "lineHeight": {
      "display": { "value": 0.88, "type": "number", "description": "Hero headlines — tight, commanding" },
      "heading": { "value": 1.05, "type": "number" },
      "body":    { "value": 1.55, "type": "number" },
      "caption": { "value": 1.30, "type": "number" }
    },
    "letterSpacing": {
      "tight":  { "value": "-0.02em", "type": "dimension", "description": "Display headlines" },
      "body":   { "value": "0",        "type": "dimension" },
      "caps":   { "value": "0.10em",   "type": "dimension", "description": "All-caps labels and tags" },
      "wide":   { "value": "0.14em",   "type": "dimension", "description": "Chrome and micro-labels" }
    }
  },
  "space": {
    "1":  { "value": "4px",   "type": "dimension" },
    "2":  { "value": "8px",   "type": "dimension" },
    "3":  { "value": "12px",  "type": "dimension" },
    "4":  { "value": "16px",  "type": "dimension", "description": "Default gap between panels/cards" },
    "5":  { "value": "20px",  "type": "dimension" },
    "6":  { "value": "24px",  "type": "dimension", "description": "Dark card internal padding" },
    "7":  { "value": "32px",  "type": "dimension", "description": "Outer slide margin" },
    "8":  { "value": "40px",  "type": "dimension" },
    "10": { "value": "64px",  "type": "dimension" },
    "12": { "value": "96px",  "type": "dimension" },
    "16": { "value": "128px", "type": "dimension" }
  },
  "radius": {
    "card":  { "value": "16px",  "type": "dimension" },
    "small": { "value": "8px",   "type": "dimension" },
    "pill":  { "value": "100px", "type": "dimension" },
    "none":  { "value": "0px",   "type": "dimension" }
  },
  "shadow": {
    "card":   { "value": "0 1px 2px rgba(0,0,0,0.06), 0 8px 32px rgba(0,0,0,0.10)", "type": "shadow" },
    "glow":   { "value": "0 0 80px rgba(90,40,221,0.30)",                             "type": "shadow" },
    "purple": { "value": "0 4px 24px rgba(90,40,221,0.40)",                           "type": "shadow" },
    "lift":   { "value": "0 20px 60px rgba(0,0,0,0.50)",                              "type": "shadow" }
  },
  "motion": {
    "easeOut":      { "value": "cubic-bezier(0.16, 1, 0.3, 1)", "type": "cubicBezier" },
    "easeInOut":    { "value": "cubic-bezier(0.45, 0, 0.55, 1)", "type": "cubicBezier" },
    "durationFast": { "value": "160ms", "type": "duration" },
    "durationBase": { "value": "280ms", "type": "duration" },
    "durationSlow": { "value": "520ms", "type": "duration" }
  },
  "canvas": {
    "slide": {
      "width":  { "value": "1440px", "type": "dimension" },
      "height": { "value": "810px",  "type": "dimension" },
      "aspect": { "value": "16:9",   "type": "string" }
    }
  },
  "logo": {
    "colorways": {
      "gradient":   { "description": "Default — all digital touchpoints, websites, pitch decks, social" },
      "solidPurple":{ "description": "Brand alternative — merchandise, stickers, screen-printed materials" },
      "monoDark":   { "description": "Black on light — printing, embossing, engraving" },
      "monoLight":  { "description": "White on dark — photography overlays, video" },
      "solidCoral": { "description": "Campaign only — special events, collaborations. Never default." }
    },
    "versions": {
      "short": { "elements": "Icon + Layout",        "use": "Primary — all visual-first touchpoints" },
      "full":  { "elements": "Icon + Layout Studio", "use": "Formal — contracts, proposals, legal docs" }
    },
    "clearspace": { "value": "X (icon height / 2)", "description": "Minimum clear space around logo on all sides" },
    "minSize": {
      "print":   "30mm",
      "display": "100px",
      "icon": { "print": "7mm", "display": "24px" }
    },
    "donts": [
      "Don't stretch horizontally or vertically",
      "Don't use wordmark alone without icon",
      "Don't rotate",
      "Don't change icon/wordmark relationship",
      "Don't add drop shadows",
      "Don't add strokes",
      "Don't place on busy backgrounds",
      "Don't overuse gradients or effects"
    ]
  },
  "grid": {
    "L01": { "description": "Narrow left column (22%) + 2×2 right grid",       "columns": "22% 1fr" },
    "L02": { "description": "Narrow left (22%) + top 2-col + wide bottom",      "columns": "22% 1fr" },
    "L03": { "description": "Narrow left (22%) + 2 stacked panels",             "columns": "22% 1fr" },
    "L04": { "description": "Narrow left (22%) + single large panel",           "columns": "22% 1fr" },
    "L05": { "description": "4-column top row + full-width banner bottom",      "columns": "repeat(4, 1fr)" },
    "L06": { "description": "4 equal columns",                                   "columns": "repeat(4, 1fr)" },
    "L07": { "description": "3 equal columns",                                   "columns": "repeat(3, 1fr)" }
  },
  "voice": {
    "tagline":     { "value": "Shaping the visual layer of Web3." },
    "positioning": { "value": "You build the product. We build the visual layer." },
    "valueProp":   { "value": "One studio. Full-stack visual. Ecosystem native." },
    "mission":     { "value": "Every ambitious company deserves design that matches the scale of what they're building." },
    "pillars": [
      { "num": "01", "name": "Ecosystem Native",   "tag": "Culture" },
      { "num": "02", "name": "Full-Stack Visual",  "tag": "Discipline" },
      { "num": "03", "name": "Built to Ship",      "tag": "Execution" },
      { "num": "04", "name": "Work Without Borders","tag": "Reach" }
    ]
  }
}
