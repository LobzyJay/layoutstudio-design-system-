    "7":  { "value": "30px", "type": "dimension", "description": "Outer slide margin" },
    "8":  { "value": "40px", "type": "dimension" },
    "10": { "value": "64px", "type": "dimension" },
    "12": { "value": "96px", "type": "dimension" }
