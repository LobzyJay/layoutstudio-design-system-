    "durationBase": { "value": "280ms", "type": "duration" },
    "durationSlow": { "value": "520ms", "type": "duration" }
  },
  "grid": {
    "L01": { "description": "Split column (24%) + 2×2 grid",            "columns": "24% 1fr" },
    "L02": { "description": "Split column (24%) + wide bottom span",     "columns": "24% 1fr" },
    "L03": { "description": "Split column (24%) + 2 stacked wide",       "columns": "24% 1fr" },
    "L04": { "description": "Split column (24%) + single large panel",   "columns": "24% 1fr" },
    "L05": { "description": "4 columns + full-width banner bottom",      "columns": "repeat(4, 1fr)" },
    "L06": { "description": "4 equal columns",                            "columns": "repeat(4, 1fr)" },
    "L07": { "description": "3 equal columns",                            "columns": "repeat(3, 1fr)" }
  },
  "voice": {
    "tagline":     { "value": "We design for companies building the future." },
    "positioning": { "value": "You build the product. We build the visual layer." },
    "valueProp":   { "value": "One studio. Full-stack visual. Ecosystem native." },
    "mission":     { "value": "Every ambitious company deserves design that matches the scale of what they're building." }
